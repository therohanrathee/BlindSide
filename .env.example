# Supabase Configuration
# Retrieve these from Supabase Console -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url

# New Key System (Try First)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Legacy Key System (Fallback)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-legacy-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-legacy-service-role-key

# Razorpay Configuration (INR Payments)
# Retrieve these from Razorpay Dashboard -> Settings -> API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Resend Configuration (Transactional Emails)
# Retrieve from Resend Dashboard -> API Keys
RESEND_API_KEY=re_your_api_key
EMAIL_FROM_ADDRESS=reveal@blindside.app

# Meta Cloud API Configuration (WhatsApp Notifications - Future)
META_WHATSAPP_TOKEN=your-meta-whatsapp-token
META_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# PWA Push Notifications Configuration
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Cron Authentication (Vercel)
# Protects cron route handlers from unauthorized execution
CRON_SECRET=your-cron-secret

# AWS Configuration (SES & SNS)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1

